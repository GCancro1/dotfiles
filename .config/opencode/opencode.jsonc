{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
		"./tools/philosophy.md"
	],
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": {
					"*": "deny"
				},
        "task": "allow",
				"write": "deny",
				"worktree_*": "allow"
			},
			"prompt": "You are a **build orchestrator**. You coordinate implementation through delegation - you do NOT implement directly.\\\\\\\\n\\\\\\\\n## Your Role\\\\\\\\n- Delegate implementation to `coder`\\\\\\\\n- Delegate documentation to `scribe`\\\\\\\\n- Delegate codebase analysis to `explore`\\\\\\\\n- Delegate external research to `researcher`\\\\\\\\n- Interpret results and decide next steps\\\\\\\\n\\\\\\\\n## Critical Constraint\\\\\\\\nYou CANNOT edit files or run commands directly. For ALL implementation and verification, delegate to `coder`."
    },
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "ls*": "allow",
          "find*": "allow"
				},
				"write": "deny",
				"task": "allow",
				"worktree_*": "allow"
      }
    },
    "researcher": {
      "description": "External research using MCP tools, read-only",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": {
					"*": "deny",
					"gh repo view*": "allow",
					"gh pr view*": "allow",
					"gh pr list*": "allow",
					"gh issue view*": "allow",
					"gh issue list*": "allow",
					"gh release view*": "allow",
					"gh release list*": "allow",
					"gh run view*": "allow",
					"gh run list*": "allow",
					"gh workflow list*": "allow",
					"gh search *": "allow",
					"gh api *": "allow",
					"npm view*": "allow",
					"npm info*": "allow",
					"npm show*": "allow",
					"pip show*": "allow",
					"pip index*": "allow",
					"cargo search*": "allow",
					"cargo info*": "allow",
					"man *": "allow",
					"tldr *": "allow",
					"dig *": "allow",
					"nslookup *": "allow",
					"whois *": "allow",
					"host *": "allow",
					"jq *": "allow",
					"head *": "allow",
					"tail *": "allow",
					"base64 *": "allow",
					"grep *": "allow",
					"rg *": "allow",
					"wc *": "allow",
					"sort *": "allow",
					"uniq *": "allow",
					"cut *": "allow",
					"awk *": "allow",
					"tr *": "allow"
				},
        "webfetch": "allow",
				"websearch": "allow",
				"context7_*": "allow",
				"exa_*": "allow",
				"gh_grep_*": "allow",
				"kagi_*": "deny",
				"write": "deny",
				"plan_read": "deny",
				"todoread": "deny"
      }
    },
    "coder": {
      "description": "Implementation specialist with full file and bash access",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
				"bash": "allow",
				"context7_*": "deny",
				"exa_*": "deny",
				"gh_grep_*": "deny",
				"read": "allow",
				"write": "allow",
				"glob": "allow",
				"grep": "allow",
				"plan_read": "deny",
				"todoread": "deny"
      }
    },
    "scribe": {
      "description": "Documentation writer, file write only",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": {
					"*": "deny"
				},
				"glob": "allow",
				"read": "allow",
				"write": "allow",
				"plan_read": "deny",
				"todoread": "deny"
      }
    },
    "reviewer": {
      "description": "Code review specialist, read-only with git inspection",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
					"git log*": "allow",
					"git show*": "allow",
					"git blame*": "allow",
					"rg *": "allow"
				},
				"write": "deny",
				"plan_read": "allow",
				"delegation_read": "allow",
				"delegation_list": "allow"
			},
			"temperature": 0.1
		},
		"explore": {
			"permission": {
				"edit": "deny",
				"write": "deny",
				"plan_read": "deny",
				"todoread": "deny",
				"bash": {
					"*": "deny",
					"ls *": "allow",
					"tree *": "allow",
					"pwd": "allow",
					"cat *": "allow",
					"head *": "allow",
					"tail *": "allow",
					"wc *": "allow",
					"file *": "allow",
					"stat *": "allow",
					"grep *": "allow",
					"rg *": "allow",
					"find *": "allow",
					"git status*": "allow",
					"git log*": "allow",
					"git diff*": "allow",
					"git show*": "allow",
					"git blame*": "allow",
					"git branch*": "allow",
					"git ls-files*": "allow",
					"uname*": "allow",
					"hostname": "allow",
					"whoami": "allow",
					"which *": "allow",
					"realpath *": "allow"
				}
			}
		}
	},
	"permission": {
		"task": "deny",
		"context7_*": "deny",
		"exa_*": "deny",
		"gh_grep_*": "deny",
		"kagi_*": "deny",
		"webfetch": "deny",
		"worktree_*": "deny"
	},
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true
		},
		"gh_grep": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		}
	},
	"plugin": [
		"@tarquinen/opencode-dcp@3.1.3",
		"@franlol/opencode-md-table-formatter@0.0.6",
		"opencode-diff"
	]
}
