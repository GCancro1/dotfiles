{
    "appearance": {
        "transparency": {
            "enabled": true
        }
    },
    "bar": {
        "persistent": true,
        "showOnHover": false,
        "status": {
            "showAudio": true,
            "showKbLayout": false,
            "showLockStatus": false,
            "showMicrophone": true
        },
        "tray": {
            "background": true,
            "compact": false,
            "recolour": true
        },
        "workspaces": {
            "activeIndicator": true,
            "activeTrail": true,
            "occupiedBg": false,
            "showWindows": true,
            "showWindowsOnSpecialWorkspaces": true
        }
    },
    "dashboard": {
        "enabled": true,
        "mediaUpdateInterval": 500,
        "resourceUpdateInterval": 10000,
        "showOnHover": false
    },
    "general": {
        "idle": {
            "inhibitWhenAudio": true,
            "lockBeforeSleep": true,
            "timeouts": [
                {
                    "idleAction": "lock",
                    "timeout": 180
                },
                {
                    "idleAction": "dpms off",
                    "returnAction": "dpms on",
                    "timeout": 300
                },
                {
                    "idleAction": [
                        "suspendThenHibernate"
                    ],
                    "timeout": 600
                }
            ]
        }
    },
    "launcher": {
        "enableDangerousActions": true,
        "showOnHover": false,
        "useFuzzy": {
            "apps": true
        },
        "vimKeybinds": true
    },
    "sidebar": {
        "dragThreshold": 0
    }
}
